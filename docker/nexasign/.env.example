# ─────────────────────────────────────────────────────────────────
# NexaSign .env — kopieren zu .env und Werte setzen
# ─────────────────────────────────────────────────────────────────

# ── Postgres ────────────────────────────────────────────────────
POSTGRES_USER=nexasign
# Muss URL-sicher sein, weil compose.yml daraus die Prisma-DB-URL baut.
# Beispiel: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGEME_DB_PASSWORD
POSTGRES_DB=nexasign

# ── App-Secrets (alle mit `openssl rand -base64 32` generieren) ──
NEXTAUTH_SECRET=CHANGEME_NEXTAUTH_SECRET
NEXT_PRIVATE_ENCRYPTION_KEY=CHANGEME_ENCRYPTION_KEY
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=CHANGEME_ENCRYPTION_SECONDARY_KEY

# ── Öffentliche URL ─────────────────────────────────────────────
NEXT_PUBLIC_WEBAPP_URL=https://sign.nexastack.co

# ── SMTP ────────────────────────────────────────────────────────
# Beispiel: Resend, Postmark, eigener SMTP-Relay.
# Für ersten lokalen Test reicht ein Dummy — die App startet trotzdem,
# nur der Versand von Einladungs-Mails schlägt fehl.
NEXT_PRIVATE_SMTP_TRANSPORT=smtp-auth
NEXT_PRIVATE_SMTP_HOST=smtp.example.com
NEXT_PRIVATE_SMTP_PORT=587
NEXT_PRIVATE_SMTP_USERNAME=
NEXT_PRIVATE_SMTP_PASSWORD=
NEXT_PRIVATE_SMTP_SECURE=true
NEXT_PRIVATE_SMTP_FROM_NAME=NexaSign
NEXT_PRIVATE_SMTP_FROM_ADDRESS=noreply@nexastack.co

# ── PDF-Signing-Cert ─────────────────────────────────────────────
# Passphrase für das Signatur-Zertifikat. Das Cert wird im Volume
# nexasign-cert unter /opt/nexasign/cert.p12 erwartet.
#
# WICHTIG: Ohne gültiges Cert bleibt jedes signierte Dokument auf Status
# „Ausstehend" hängen, weil der Seal-Job nach dem Signieren fehlschlägt.
#
# Setup:
#   1. Passphrase hier setzen: NEXT_PRIVATE_SIGNING_PASSPHRASE=$(openssl rand -base64 32)
#   2. Dev/Test:    ./scripts/nexasign/generate-dev-cert.sh
#      Produktion:  AATL-Cert kaufen (Certum/Sectigo/GlobalSign/D-Trust)
#                   → Details + Anbieter in SIGNING.nexafile.md
NEXT_PRIVATE_SIGNING_PASSPHRASE=CHANGEME_CERT_PASSPHRASE

# ── Optional: Signup deaktivieren ───────────────────────────────
# false = jeder kann sich registrieren (für öffentliche Instanz sinnvoll)
# true  = nur Admin kann Nutzer anlegen
NEXT_PUBLIC_DISABLE_SIGNUP=false

# ── Version-Pin (für reproduzierbare Deployments) ───────────────
# Hier den Tag setzen, den docker-compose pullen/bauen soll.
# Empfehlung: SemVer-Tag (vX.Y.Z) oder Image-Digest (sha256:...).
# Wenn nicht gesetzt, fällt compose.yml auf :latest zurück (Dev-Default).
NEXASIGN_VERSION=v0.1.0-beta.1
