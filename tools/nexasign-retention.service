[Unit]
Description=NexaSign GoBD Retention-Check
Documentation=https://nexasign.nexastack.co/vorlagen/gobd/
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/opt/NexaSign/tools/nexasign-retention-check.sh
User=root
Nice=10
StandardOutput=journal
StandardError=journal
