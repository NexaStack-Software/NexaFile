# ──────── NexaSign-spezifisch ────────

# Composer-Artefakte (Dependencies werden via `composer install` lokal installiert)
templates/*/vendor/
templates/*/composer
templates/*/composer-setup.php
templates/*/installer.sig

# Persönliche Assets (werden nicht im OSS-Repo verbreitet)
Emilian Buza.jpg
img/26864.jpg
packages/assets/images/emilian.webp

# Logo-Backups (Originale liegen nur lokal als Wiederherstellungs-Punkt)
img/*.original.png

# Generierte Logo-Artefakte (Zwischenstände bei Logo-Generierung)
tmp-logo/

# Ad-hoc-Build-Logs (werden im /tmp erzeugt, aber für den Fall)
/tmp/nx-*.log

# ──────── NexaSign Operator-/Demo-Stack (privat, NICHT in OSS-Repo) ────────
# Diese Dateien gehören in ein privates NexaStack-Infra-Repo, nicht hierher.
# Falls sie versehentlich lokal landen, blockiert .gitignore das Tracking.
archive/
!packages/lib/server-only/sources/archive/
!packages/lib/server-only/sources/archive/**
demo/
Demo/
DEMO.nexasign.md
README.upstream.md
docker/nexasign-demo/
docker/nexasign-demo.compose.yml
scripts/nexasign/reset-demo.sh
scripts/nexasign/seed-demo.sh
scripts/nexasign/seed-demo*.mjs
scripts/nexasign/seed-demo*.ts

# Lokale Operator-Konfiguration und Backups
.env.operator
.env.operator.*
backups/
*.backup.gz
*.backup.tar.zst

# ──────── Explicit build artefact paths (defense in depth) ────────
# Catch-all `build` and `.next/` lines above are intentional, but explicit
# paths make the intent unmistakable and survive accidental glob removal.
apps/remix/build/
apps/docs/.next/
apps/docs/build/
apps/docs/out/
apps/openpage-api/.next/

# Turbo per-package caches
apps/*/.turbo/
packages/*/.turbo/

# Coverage & test artefacts
coverage/
.nyc_output/
playwright-report/
test-results/

# Prisma client output (generated, never tracked)
packages/prisma/generated/
